.DS_Store
images/.DS_Store
.claude/*
!.claude/settings.json
media-library/
.venv/
scripts/node_modules/
_site/

# Internal project notes and AI memory (not part of the website)
memory/
reports/
google-ads-*.md

# Ad creative assets not yet integrated into the live site
limitless-logo-square-1200.png
__pycache__/
*.pyc

# Google Ads API secrets (local only)
scripts/google-ads/google-ads.yaml
scripts/google-ads/client_secrets.json
scripts/google-ads/.venv/

# Generated marketing deliverable — not website source, and Netlify serves the repo
# root, so committing this would publish it publicly. Regenerate on demand instead.
Limitless-Charter-Presentation.pdf

# Shared agent workspace (.agent/) — ALWAYS tracked so agents share it, even though the
# broader rules above ignore memory/ and google-ads-*.md. It never ships to main (stripped
# by the main pre-commit hook + .netlifyignore).
!.agent/
!.agent/memory/
!.agent/**
