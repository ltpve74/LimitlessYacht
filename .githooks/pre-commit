#!/bin/sh
# Auto-rebuild the localized pages (de/es/fr) whenever the English sources or the
# locale translation data are part of a commit, so the localized pages never
# silently drift out of sync with index.html / legal.html again.
#
# Enable once per clone with:
#   git config core.hooksPath .githooks
#
# Note: build-locales.py reads the working-tree index.html, so commit a clean
# tree (stage your HTML edits before committing) for the rebuild to match.

set -e

# Skip locale rebuilds on non-main branches (UX work doesn't need them).
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$BRANCH" != "main" ]; then
  exit 0
fi

CHANGED=$(git diff --cached --name-only)

if printf '%s\n' "$CHANGED" | grep -qE '^(index\.html|legal\.html|css/main\.css|scripts/minify_html\.py|i18n/locales/[^/]+\.py|i18n/build-locales\.py)$'; then
  echo "[pre-commit] EN source / CSS / locale data changed — rebuilding locales + minifying for prod..."

  # Prefer the project venv; fall back to python3.
  if [ -x ".venv/bin/python" ]; then
    PY=".venv/bin/python"
  else
    PY="python3"
  fi

  if ! "$PY" i18n/build-locales.py; then
    echo "[pre-commit] ERROR: locale build failed — aborting commit." >&2
    exit 1
  fi

  # Minify HTMLs + the shared CSS (produces the compacted prod versions for main).
  if ! "$PY" scripts/minify_html.py; then
    echo "[pre-commit] ERROR: minify failed — aborting commit." >&2
    exit 1
  fi

  # Run site tests on the freshly minified locale files.
  # Blocks commit if any conversion-critical element is missing or JS has syntax errors.
  echo "[pre-commit] Running site tests..."
  if ! "$PY" scripts/test-site.py; then
    echo "[pre-commit] ERROR: site tests failed — fix the issues above and try again." >&2
    exit 1
  fi

  # Re-stage the compacted sources, CSS, and all regenerated (minified) locale files.
  git add index.html legal.html css/main.css \
          de/index.html de/legal.html es/index.html es/legal.html fr/index.html fr/legal.html
  echo "[pre-commit] Locales rebuilt + minified, all staged for main."
fi

exit 0
