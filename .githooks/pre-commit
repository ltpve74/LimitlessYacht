#!/bin/sh
# Branch-aware pre-commit hook.
#
# experiment-no-prices (dev): rebuild locales when EN source changes — keep HTML/CSS readable.
# main (production): rebuild locales → minify → test — publishing step only.
#
# Enable once per clone with:
#   git config core.hooksPath .githooks
#
# Note: build-locales.py reads the working-tree index.html, so stage HTML
# edits before committing so the rebuild matches the committed content.

set -e

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

# Prefer the project venv; fall back to python3.
if [ -x ".venv/bin/python" ]; then
  PY=".venv/bin/python"
else
  PY="python3"
fi

CHANGED=$(git diff --cached --name-only)

LOCALE_REBUILD=0
if printf '%s\n' "$CHANGED" | grep -qE '^(index\.html|legal\.html|i18n/locales/[^/]+\.py|i18n/build-locales\.py)$'; then
  LOCALE_REBUILD=1
fi

if [ "$BRANCH" = "experiment-no-prices" ]; then
  if [ "$LOCALE_REBUILD" -eq 1 ]; then
    echo "[pre-commit] EN source / locale data changed — rebuilding locales (readable dev branch)..."
    if ! "$PY" i18n/build-locales.py; then
      echo "[pre-commit] ERROR: locale build failed — aborting commit." >&2
      exit 1
    fi
    git add de/index.html de/legal.html es/index.html es/legal.html fr/index.html fr/legal.html
    echo "[pre-commit] Locales rebuilt and staged (no minification on dev branch)."
  fi
  exit 0
fi

if [ "$BRANCH" != "main" ]; then
  exit 0
fi

if [ "$LOCALE_REBUILD" -eq 1 ]; then
  echo "[pre-commit] EN source / locale data changed — rebuilding locales..."
  if ! "$PY" i18n/build-locales.py; then
    echo "[pre-commit] ERROR: locale build failed — aborting commit." >&2
    exit 1
  fi
fi

echo "[pre-commit] Minifying CSS + HTML for production..."
if ! "$PY" scripts/minify_html.py; then
  echo "[pre-commit] ERROR: minify failed — aborting commit." >&2
  exit 1
fi

echo "[pre-commit] Running site tests..."
if ! "$PY" scripts/test-site.py; then
  echo "[pre-commit] ERROR: site tests failed — fix the issues above and try again." >&2
  exit 1
fi

git add index.html legal.html css/main.css \
        de/index.html de/legal.html es/index.html es/legal.html fr/index.html fr/legal.html
echo "[pre-commit] Minified + staged for main."

exit 0
