#!/bin/sh
# Branch-aware pre-commit hook.
#
# develop (integration): rebuild locales when EN source changes — keep HTML/CSS readable.
# feature branches: same as develop — rebuild locales, no minify.
# main (production): minify → test only (locales already built on dev branch before merge).
#
# Enable once per clone with:
#   git config core.hooksPath .githooks
#
# Note: build-locales.py reads the working-tree index.html, so stage HTML
# edits before committing so the rebuild matches the committed content.

set -e

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

# Prefer the project venv; fall back to python3.
if [ -x ".venv/bin/python" ]; then
  PY=".venv/bin/python"
else
  PY="python3"
fi

# Decision guards: block silently weakening a DECISION-tagged test (see DECISIONS.md).
# These tests encode load-bearing choices; changing one to make a diff pass undoes a decision.
if ! "$PY" scripts/check-decision-guards.py; then
  echo "[pre-commit] ERROR: a DECISION-guarded test changed without acknowledgement (see above)." >&2
  echo "[pre-commit] If intentional: update DECISIONS.md, then run 'python3 scripts/check-decision-guards.py --accept' and stage the lock." >&2
  exit 1
fi

CHANGED=$(git diff --cached --name-only)

# Readable-source guard (non-main branches): a minified index.html/main.css on the
# integration branch means a main->develop back-merge happened (Jun 2026 incident:
# a "Publish:" commit merged into the lineage left develop minified for weeks).
# Minified = almost no newlines. Block the commit before the damage spreads.
if [ "$BRANCH" != "main" ]; then
  for f in index.html legal.html css/main.css css/layout.css; do
    if printf '%s\n' "$CHANGED" | grep -qx "$f"; then
      LINES=$(git show ":$f" 2>/dev/null | wc -l)
      if [ "$LINES" -lt 50 ]; then
        echo "[pre-commit] ERROR: $f is being committed with only $LINES lines on branch '$BRANCH'." >&2
        echo "[pre-commit] That looks MINIFIED. Source branches must stay readable (see DECISIONS.md 'Build / git')." >&2
        echo "[pre-commit] Did a main->develop merge sneak in, or did scripts/minify_html.py run here?" >&2
        exit 1
      fi
    fi
  done
fi

LOCALE_REBUILD=0
if printf '%s\n' "$CHANGED" | grep -qE '^(index\.html|legal\.html|data/reviews\.json|i18n/locales/[^/]+\.py|i18n/build-locales\.py)$'; then
  LOCALE_REBUILD=1
fi

if printf '%s\n' "$CHANGED" | grep -qE '^css/layout\.css$'; then
  echo "[pre-commit] css/layout.css changed — bumping layout cache version..."
  if ! "$PY" scripts/bump-css-cache.py --layout; then
    echo "[pre-commit] ERROR: layout.css cache bump failed — aborting commit." >&2
    exit 1
  fi
  git add index.html
  LOCALE_REBUILD=1
fi

if printf '%s\n' "$CHANGED" | grep -qE '^css/main\.css$'; then
  echo "[pre-commit] css/main.css changed — bumping main cache version..."
  if ! "$PY" scripts/bump-css-cache.py --main; then
    echo "[pre-commit] ERROR: main.css cache bump failed — aborting commit." >&2
    exit 1
  fi
  git add index.html
  LOCALE_REBUILD=1
fi

if [ "$BRANCH" != "main" ]; then
  if [ "$LOCALE_REBUILD" -eq 1 ]; then
    echo "[pre-commit] EN source / locale data changed — rebuilding locales..."
    if ! "$PY" i18n/build-locales.py; then
      echo "[pre-commit] ERROR: locale build failed — aborting commit." >&2
      exit 1
    fi
    git add de/index.html de/legal.html es/index.html es/legal.html fr/index.html fr/legal.html \
            data/reviews-de.json data/reviews-es.json data/reviews-fr.json
    echo "[pre-commit] Locales + review JSON rebuilt and staged (no minification on non-main branch)."
  fi
  exit 0
fi

if [ "$LOCALE_REBUILD" -eq 1 ]; then
  echo "[pre-commit] CSS version bumped — rebuilding locales before minify..."
  if ! "$PY" i18n/build-locales.py; then
    echo "[pre-commit] ERROR: locale build failed — aborting commit." >&2
    exit 1
  fi
  git add de/index.html de/legal.html es/index.html es/legal.html fr/index.html fr/legal.html \
          data/reviews-de.json data/reviews-es.json data/reviews-fr.json
fi

echo "[pre-commit] Minifying CSS + HTML + js/ for production..."
if ! "$PY" scripts/minify_html.py; then
  echo "[pre-commit] ERROR: minify failed — aborting commit." >&2
  exit 1
fi

echo "[pre-commit] Running publish gate (site tests + UX + Lighthouse)..."
export PUBLISH_GATE_PYTHON="$PY"
if ! "$PY" scripts/publish-gate.py ${PUBLISH_GATE_EXTRA_ARGS:-}; then
  echo "[pre-commit] ERROR: publish gate failed — fix the issues above and try again." >&2
  echo "[pre-commit] One-time setup: scripts/setup-qa.sh" >&2
  exit 1
fi

git add index.html legal.html css/layout.css css/main.css js/*.js \
        de/index.html de/legal.html es/index.html es/legal.html fr/index.html fr/legal.html \
        data/reviews-de.json data/reviews-es.json data/reviews-fr.json
echo "[pre-commit] Minified + staged for main."

exit 0
